;;; conjurer-mcp.cnj
;;; Project anchor for the Conjurer MCP toolchain.
;;; This file holds the charter, shared assets, and operative constraints.
;;; Per-deliverable domain work lives in the referenced .cnj files:
;;;   mcp-server.cnj       — the stdio MCP server
;;;   vscode-extension.cnj — the VS Code extension (VSIX)
;;; The shared core (parser, types, spec-reader) is modelled in mcp-server.cnj
;;; Section VI, since the server is its primary consumer and the extension
;;; depends on it.

;;; ─────────────────────────────────────────────────────────────────
;;; Section 1 — Charter
;;; ─────────────────────────────────────────────────────────────────

(charter "Conjurer MCP Toolchain"
  :version  "0.1.0"
  :created  "2026-06-05"
  :updated  "2026-06-05"
  :domain   "A local-first Model Context Protocol server, and companion VS Code
             extension, that serve targeted Conjurer specification content —
             symbols, sections, examples, validation — to an IDE coding agent so
             the agent need not load the full spec into its context window."
  :language :en

  :goals [
    "Reduce the context/token load on a local IDE agent working with Conjurer:
     return precisely the symbol, section, example, or validation result needed,
     instead of forcing the agent to read whole grimoire files."
    "Parse and validate .cnj files structurally, so the agent inherits
     correctness checks rather than re-deriving the spec's rules each session."
    "Run locally over stdio with no external hosting and no LLM inside the
     server — all intelligence stays in the calling agent; the server is a
     deterministic retrieval, parse, and validation service."
    "Ship as a modular TypeScript codebase (TSF++), never again a single
     multi-thousand-line file, with the VS Code extension sharing the server's
     core logic rather than duplicating it."]

  :audience {:primary   :senior-engineer
             :secondary [:engineer]}

  :decisions [
    {:date "2026-06-05"
     :decision "Three-file .cnj decomposition (option 3): this project anchor,
                plus mcp-server.cnj and vscode-extension.cnj. The file split
                mirrors the monorepo package split, so each real deliverable has
                its own charter outputs entry and target declaration. Chosen over
                a single .cnj because the server and extension are genuinely
                separate artefacts that nonetheless share a core."}
    {:date "2026-06-05"
     :decision "No LLM integration inside the MCP server. The server is purely
                deterministic: retrieval, EDN/s-expression parsing, and rule-based
                validation. All generative/inferential work remains the calling
                agent's job. Rationale: keeps the server small, testable, fast,
                and free of API keys or model dependencies for a solo, local,
                stdio-first deployment."}
    {:date "2026-06-05"
     :decision "Fastest-lookup strategy: parse index.edn once at startup into an
                in-memory symbol map; lazy-load and cache grimoire files on first
                access; invalidate a cached file by mtime check. No per-call disk
                read after warmup. index.edn is the routing layer; grimoire files
                are the depth layer, fetched only when depth is requested."}
    {:date "2026-06-05"
     :decision "A real EDN / s-expression parser (not regex section-matching).
                It serves three consumers at once: reading index.edn, parsing
                .cnj files (parse_cnj), and underpinning validation (validate_cnj).
                One robust parser lowers the net cost of the whole parse/validate
                cluster. A prior project proved this approach robust."}
    {:date "2026-06-05"
     :decision "v1 tool surface: the full retrieval cluster (lookup_symbol,
                search_symbols, get_grimoire_section, get_examples, list_grimoire),
                plus parse_cnj, read_charter, and validate_cnj. parse_cnj is
                promoted into v1 because the EDN parser exists anyway for
                validation, so exposing it as a tool is nearly free."}
    {:date "2026-06-05"
     :decision "VS Code extension authored as modular TypeScript and bundled with
                esbuild to dist/extension.js. The single-file bundle is a build
                artefact, not source; source obeys the same module-size limits as
                the server. Fixes the prior single extension.js problem."}
    {:date "2026-06-05"
     :decision "Monorepo with a shared @conjurer/core package (parser, types,
                spec-reader) consumed by both the server and the extension, so
                parser and type definitions are never duplicated."}]

  :open [
    "Distribution: is npm publication of the server in scope for v1, or is a
     local build (npm link / file path) sufficient for the solo use case?"
    "Should the spec source be located by env var (CONJURER_SPEC_PATH),
     CLI flag, config file, or upward directory search — or several with a
     precedence order? (See spec-source-resolution in mcp-server.cnj :open.)"
    "Does the VS Code extension talk to the spec via the shared core directly,
     or by spawning the MCP server as a subprocess and speaking MCP to it?
     (Deferred until server v1 is stable — see vscode-extension.cnj.)"
    "Deferred validation depth: validate_symbol_usage, check_references, and
     lint_conventions (sentence-case, fence balance, no numeric prefixes) —
     v2 candidates, scored but not in v1."]

  :outputs {
    :shared-core        (target :typescript :standard :tsf-plus-plus)
    :mcp-server         (target :typescript :standard :tsf-plus-plus)
    :vscode-extension   (target :typescript :standard :tsf-plus-plus)
    :tool-contracts     :conjurer-only}   ;; the tool I/O specs stay as Conjurer spec

  :references ["mcp-server.cnj" "vscode-extension.cnj"]
  :tags       [:tooling :mcp :typescript :developer-experience])

;;; ─────────────────────────────────────────────────────────────────
;;; Section 2 — Assets (shared standards; referenced, not embedded)
;;; ─────────────────────────────────────────────────────────────────

(asset :tsf-plus-plus
  :type        :code-standard
  :description "TypeScript Style Foundation++ — the project's TypeScript coding
                standard. Its load-bearing rule for this project: module size is
                capped at 400 lines, 800 with an explicit, justified deviation.
                No god-files. One responsibility per module."
  :language    :typescript
  :location    "standards/tsf-plus-plus.md"
  :version     "1.0.0"
  :enforces    ["Max 400 lines per module; 800 only with a documented deviation"
                "One clear responsibility per module; split when a second emerges"
                "Explicit exported types at every package boundary"
                "Pure functions where practical; isolate I/O at the edges"]
  :prohibits   ["God-files (the prior 4000-line index.ts is the named anti-pattern)"
                "Duplicating parser or type logic across packages"
                "any types at package boundaries"]
  :applies-to  [:shared-core :mcp-server :vscode-extension]
  :active-in   :project)

(asset :mcp-protocol
  :type        :domain-vocabulary
  :description "Model Context Protocol — the JSON-RPC-based contract between an
                MCP client (the IDE agent) and server. Defines tools (callable
                functions), resources (addressable read-only context), and the
                stdio and HTTP transports. This project uses tools (and possibly
                resources) over stdio."
  :location    "https://modelcontextprotocol.io"
  :version     "2025-06-18"   ;; protocol revision; confirm against SDK at build time
  :enforces    ["Tools declare a name, description, and JSON-Schema input schema"
                "Tool results are content blocks (text/structured), not raw values"
                "stdio transport: server reads JSON-RPC on stdin, writes on stdout;
                 all logging goes to stderr, never stdout"]
  :prohibits   ["Writing diagnostic output to stdout on the stdio transport
                 (it corrupts the JSON-RPC stream)"]
  :applies-to  [:mcp-server]
  :active-in   :project)

(asset :conjurer-spec
  :type        :domain-vocabulary
  :description "The Conjurer specification itself — ten grimoire markdown files
                plus index.edn (machine-readable symbol catalog), quick-reference.md,
                conjurer.md (philosophy), and template.md (.cnj structure). This is
                the DATA the server serves. It is referenced by a local path or
                symlink, never copied into the project."
  :language    :en
  :location    "../conjurer-spec"   ;; relative path or symlink; resolved at runtime
  :version     "spec catalog 1.2.0"
  :enforces    ["index.edn is the authoritative symbol catalog and routing layer"
                "Grimoire files live under grimoires/ (e.g. grimoires/web.md)"
                "The server treats the spec as read-only; it never mutates it"]
  :prohibits   ["Embedding spec content in the server build (it must read the
                 live spec so updates require no rebuild)"]
  :applies-to  [:shared-core :mcp-server]
  :active-in   :project)

;;; ─────────────────────────────────────────────────────────────────
;;; Section 3 — Assume (operative constraints for the whole toolchain)
;;; ─────────────────────────────────────────────────────────────────

(assume conjurer-mcp-constraints
  :environment  :local-developer-workstation
  :scale        {:users :solo
                 :spec-size "~10 grimoires, ~127 symbols, low-thousands of lines total"
                 :call-volume :interactive}   ;; one agent, human-paced; not a service
  :team         {:size 1 :role :solo-maintainer}
  :infrastructure {:runtime :node
                   :language :typescript
                   :transport :stdio              ;; HTTP/hosting explicitly out of scope for v1
                   :bundler :esbuild
                   :test :node-test-runner-or-vitest
                   :repo :monorepo}
  :constraints [
    "No LLM, no network calls, no API keys inside the server — fully deterministic"
    "stdio transport must work; remote/HTTP hosting is not required for v1"
    "Every source module obeys the TSF++ size limit (400/800)"
    "The server reads the live spec by path/symlink; spec updates need no rebuild"
    "Server and extension share one core package; no logic duplication"]
  :non-negotiable [
    "Deterministic behaviour — identical inputs yield identical outputs"
    "No god-files — the prior single-file failure must not recur"
    "stdout on the stdio transport carries only JSON-RPC; logs go to stderr"]
  :negotiable [
    "Test framework choice (node:test vs vitest)"
    "Whether resources are exposed in addition to tools"
    "npm publication vs local-only install for v1"])

;;; ─────────────────────────────────────────────────────────────────
;;; Section 6 — Targets (deliverable declarations; detail in referenced files)
;;; ─────────────────────────────────────────────────────────────────

;;; The shared core is the foundation both other deliverables build on.
;;; Its module decomposition is specified in mcp-server.cnj Section VI,
;;; co-located with the server that is its primary consumer.

(target :shared-core
  :language  :typescript
  :standard  :tsf-plus-plus
  :produces  [:library :type-definitions]
  :scope     [:edn-parser :spec-reader :symbol-index :cnj-model :validation-rules]
  :via       :direct)

(target :mcp-server
  :language  :typescript
  :framework :mcp-sdk
  :standard  :tsf-plus-plus
  :produces  [:stdio-mcp-server :test-suite]
  :scope     [:retrieval-tools :parse-tools :validation-tools]
  :from      :shared-core
  :via       :direct)

(target :vscode-extension
  :language  :typescript
  :framework :vscode-extension-api
  :standard  :tsf-plus-plus
  :produces  [:vsix :bundled-extension]
  :scope     [:codelens :hover :commands]
  :from      :shared-core
  :via       :direct)
