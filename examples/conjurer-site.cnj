;; conjurer-site.cnj
;; The Conjurer demo website — a single .cnj file capturing the full
;; project specification from charter to handover.
;;
;; ─── On organising large projects across multiple .cnj files ─────────────
;;
;; This project is intentionally captured in a single file to serve as a
;; comprehensive example. For larger or longer-lived projects the same content
;; splits naturally across concern-bounded files:
;;
;;   conjurer-site/
;;   ├── project.cnj          — charter, assets, team assumptions (root anchor)
;;   ├── domain.cnj           — d/model, shapes, taxonomy, reasoning rules
;;   ├── frontend.cnj         — component model, routing, state, UI targets
;;   ├── api.cnj              — endpoint design, request/response shapes, auth
;;   └── infrastructure.cnj  — deployment, CI/CD, observability, env config
;;
;; Each file has its own charter whose :version tracks separately. The root
;; project.cnj lists the others in its :references. A new session attaches
;; only the files relevant to the work at hand — attach api.cnj when designing
;; an endpoint; attach frontend.cnj when building a component. The charter's
;; :decisions log in project.cnj remains the single source of cross-cutting
;; decisions. Files that are referenced but not attached are summarised in the
;; root charter so any agent always has a map of the whole, even when working
;; on a part.
;;
;; In this example every section is in one file. The section headers below
;; show exactly where the split would occur in a multi-file layout.

;; ─────────────────────────────────────────────────────────────────────────
;; SECTION 1 — CHARTER  [project.cnj in multi-file layout]
;; ─────────────────────────────────────────────────────────────────────────

(charter "Conjurer Demo Website"
  :version  "0.3.0"
  :created  "2025-11-05"
  :updated  "2025-11-05"
  :domain   "Developer tooling; language documentation; interactive LLM demo"

  :goals [
    "Communicate what Conjurer is and why it matters in under 60 seconds"
    "Let visitors browse the grimoire library interactively — all 10 grimoires, all 107 symbols"
    "Provide an interactive playground where visitors write Conjurer and see it interpreted"
    "Lower the barrier to installing the SKILL in VS Code and Antigravity IDE"
    "Serve as the canonical public home for the Conjurer specification and MCP server"]

  :audience {:primary   :developer-evaluating-conjurer
             :secondary [:contributor :llm-researcher :architect]}

  :decisions [
    {:date "2025-11-05"
     :decision "Monorepo with pnpm workspaces. Two apps (web, api) and two
                internal packages (domain, ui). Keeps the pure functional
                core completely independent of framework concerns."}
    {:date "2025-11-05"
     :decision "Hono for the API layer — edge-compatible, functional, minimal.
                Avoids Express's imperative middleware model which conflicts
                with TSF++ boundary discipline."}
    {:date "2025-11-05"
     :decision "Vite + React 18. No Next.js — SSR is not needed at launch;
                the site is entirely static-plus-API. Revisit if SEO becomes
                a concern."}
    {:date "2025-11-05"
     :decision "Trunk-based development. main is always deployable. Feature
                flags for in-flight playground features. No long-lived branches."}
    {:date "2025-11-05"
     :decision "The playground calls the conjurer-mcp server locally in dev
                and the hosted MCP endpoint in production. The API layer proxies
                to avoid CORS and to attach the API key server-side."}
    {:date "2025-11-05"
     :decision "TSF++ standard throughout: @tsfpp/prelude for Result/Option/pipe,
                @tsfpp/boundary for Zod-driven I/O, @tsfpp/agents for MCP client
                integration. The domain package has zero runtime framework
                dependencies."}]

  :open [
    "Authentication for playground? Rate-limit by IP for now; revisit if abuse."
    "Should the grimoire browser render the .md files directly or serve pre-parsed EDN?"
    "Analytics: privacy-respecting option (Plausible?) or none at all?"]

  :outputs {
    :domain-model      :conjurer-only
    :symbol-taxonomy   :conjurer-only
    :data-shapes       :conjurer-only
    :web-app           (target :web-app
                          :language  :typescript
                          :framework :react
                          :standard  :tsfpp
                          :produces  [:spa])
    :api               (target :api
                          :language  :typescript
                          :framework :hono
                          :standard  :tsfpp
                          :produces  [:rest-api :openapi])
    :domain-package    (target :domain-pkg
                          :language  :typescript
                          :standard  :tsfpp
                          :produces  [:library])
    :ui-package        (target :ui-pkg
                          :language  :typescript
                          :framework :react
                          :standard  :tsfpp
                          :produces  [:component-library])
    :infrastructure    (target :infra
                          :language  :yaml
                          :produces  [:github-actions :dockerfile])}

  :references []
  :tags       [:conjurer :demo :developer-marketing :phase-1])

;; ─────────────────────────────────────────────────────────────────────────
;; SECTION 2 — ASSETS  [project.cnj in multi-file layout]
;; ─────────────────────────────────────────────────────────────────────────

(asset :tsfpp
  :type        :code-standard
  :description "TSF++ TypeScript coding standard. Imperative shell, pure
                functional core. Result<T,E> error handling. No throw in
                business logic. Zod at all boundaries. No for/while loops
                in core — map/filter/reduce/pipe only."
  :language    :typescript
  :location    "standards/tsfpp.md"
  :version     "1.0.0"
  :enforces    [
    "Monorepo structured as: apps/ (shell) and packages/ (core, ui)"
    "packages/domain: pure functions only — no React, no Hono, no I/O"
    "All external I/O (HTTP, user input, file system) enters through @tsfpp/boundary parsers"
    "Errors are values: Result<T, AppError> — never throw in business logic"
    "Option<T> for nullable values — never null/undefined in domain functions"
    "pipe() from @tsfpp/prelude for data transformation chains"
    "No imperative loops in packages/domain — Array.map/filter/reduce/flatMap"
    "Maximum function body length: 20 lines — decompose otherwise"
    "No any, no as casting outside boundary parsers"
    "Named exports only — no default exports anywhere"
    "Co-locate tests: feature.ts alongside feature.test.ts"]
  :prohibits   [
    "throw/catch in packages/domain"
    "React imports in packages/domain"
    "Hono/Express imports in packages/domain"
    "Direct fetch() calls outside @tsfpp/boundary adapters"
    "Barrel files (index.ts re-exporting everything)"
    "Default exports"
    "Mutable state outside React hooks and Hono handlers"
    "console.log in production code — use structured logger"]
  :applies-to  [:web-app :api :domain-package :ui-package]
  :agent       :typescript-agent
  :active-in   :project)

(asset :tsfpp-packages
  :type        :component-library
  :description "TSF++ runtime packages: prelude (fp utilities), boundary
                (I/O validation), agents (LLM/MCP client), tsconfig,
                eslint-config"
  :location    "https://github.com/your-org/tsfpp"
  :version     "latest"
  :enforces    [
    "@tsfpp/prelude: Result, Option, pipe, flow — imported from here, not reinvented"
    "@tsfpp/boundary: all Zod schemas for external I/O live in boundary modules"
    "@tsfpp/agents: MCP client and tool definitions — used in api/ only"
    "@tsfpp/tsconfig: extended in every package tsconfig.json"
    "@tsfpp/eslint-config: extended in root eslint.config.ts"]
  :active-in   :project)

(asset :trunk-based-dev
  :type        :style-guide
  :description "Trunk-based development conventions for the Conjurer site"
  :location    "docs/git-conventions.md"
  :version     "1.0.0"
  :enforces    [
    "main is always deployable — no broken commits"
    "Feature branches: feat/short-name, max 2 days lifetime"
    "Conventional commits: feat: / fix: / docs: / refactor: / chore:"
    "Rebase before merge — linear history, no merge commits on main"
    "Feature flags via src/flags.ts for in-progress features"
    "PR requires passing CI (type-check + lint + test) before merge"
    "Changesets for any published package version bumps"]
  :prohibits   [
    "Long-lived feature branches (> 2 days)"
    "Merge commits on main"
    "Direct pushes to main without CI green"]
  :active-in   :project)

;; ─────────────────────────────────────────────────────────────────────────
;; SECTION 3 — ASSUMPTIONS  [project.cnj in multi-file layout]
;; ─────────────────────────────────────────────────────────────────────────

(assume
  :environment    :production-saas
  :scale          "Low initial traffic — developer audience, <1K DAU at launch.
                   Playground calls are the expensive path (MCP/LLM). Budget
                   accordingly; add caching before scaling."
  :team           {:size 2 :skill-level :senior :roles [:fullstack :devops]}
  :infrastructure {:existing [:cloudflare-pages :cloudflare-workers :github-actions]
                   :avoid    [:kubernetes :separate-ci-cd-platform :monolithic-db]}
  :constraints    {:budget :bootstrapped :timeline "3 weeks to public launch"}
  :negotiable     [:analytics-provider :playground-llm-provider :ui-component-library]
  :non-negotiable [
    :tsfpp-standard-throughout
    :trunk-based-development
    :zero-runtime-deps-in-domain-package
    :no-user-data-stored-without-consent])

;; ─────────────────────────────────────────────────────────────────────────
;; SECTION 4 — CONTEXT  [project.cnj in multi-file layout]
;; ─────────────────────────────────────────────────────────────────────────

(context establish conjurer-site
  :domain      :developer-tooling
  :entities    {
    :grimoire   [:name :namespace :description :version :constructs]
    :symbol     [:name :namespace :grimoire :synopsis :key-params :accepts :produces]
    :example    [:id :title :grimoire :code :explanation :output-preview]
    :playground-session [:id :input :interpretation :created-at]}
  :conventions {
    :package-manager   :pnpm
    :node-version      "22"
    :typescript-strict true
    :test-framework    :vitest
    :formatting        :prettier
    :monorepo-tool     :pnpm-workspaces}
  :active-in :session)

;; ─────────────────────────────────────────────────────────────────────────
;; SECTION 5 — DOMAIN WORK  [domain.cnj in multi-file layout]
;; ─────────────────────────────────────────────────────────────────────────

;; — Data shapes (source of truth for Zod schemas in @tsfpp/boundary)

(shape grimoire
  :fields {
    :name        (string :min-length 3 :max-length 40)
    :namespace   (string :optional true :pattern "^[a-z]+/$")
    :file        (string :pattern "^grimoires/[a-z]+\\.md$")
    :description (string :max-length 200)
    :version     (string :format :semver)
    :constructs  [(map :of construct-group) :min-length 1]}
  :invariants [
    "namespace is nil only for the core grimoire"
    "every construct name in :constructs must match a symbol entry in index.edn"]
  :examples [
    {:name "domain" :namespace "d/" :file "grimoires/domain.md"
     :description "Knowledge extraction: exploring documents, modeling domains"
     :version "2.0.0" :constructs {:discovery [:d/explore :d/extract :d/refine]}}])

(shape symbol
  :fields {
    :name       (string :pattern "^[a-z~/][a-z0-9/\\-~>]*$")
    :grimoire   (string)
    :namespace  (string :optional true)
    :synopsis   (string :max-length 160)
    :key-params (vector :of keyword)
    :accepts    (vector :of keyword)
    :produces   (vector :of keyword)}
  :invariants [
    "name prefixed by namespace when namespace is not nil"
    "grimoire must reference a known grimoire name"]
  :examples [
    {:name "d/explore" :grimoire "domain" :namespace "d/"
     :synopsis "Analyse sources to extract comprehensive domain model"
     :key-params [:depth :focus :infer :output]
     :accepts [:source-url-or-file] :produces [:domain-model]}])

(shape playground-request
  :fields {
    :input    (string :min-length 1 :max-length 4000)
    :context  (map :optional true :of string)
    :session-id (string :optional true :format :uuid)}
  :invariants [
    "input must contain at least one recognisable Conjurer construct"]
  :phi-fields [])

(shape playground-response
  :fields {
    :interpretation (string :min-length 1)
    :constructs-used (vector :of string)
    :open-questions  (vector :of string :optional true)
    :session-id      (string :format :uuid)
    :elapsed-ms      (integer :min 0)}
  :invariants [
    "constructs-used references symbols from index.edn"
    "interpretation is never empty even if input was malformed"])

;; — Domain model

(d/model "Conjurer Site Domain"
  :entities {
    :grimoire  {:type :aggregate-root
                :attributes [:name :namespace :file :description :version :constructs]
                :lifecycle  [:draft :published :deprecated]}

    :symbol    {:type :entity
                :attributes [:name :grimoire :namespace :synopsis :key-params
                             :accepts :produces]
                :note "Read from index.edn at build time; treated as immutable at runtime"}

    :example   {:type :entity
                :attributes [:id :title :grimoire :code :explanation :tags]
                :note "Curated examples; authored, not generated"}

    :playground-session {:type :value-object
                         :attributes [:id :input :interpretation :constructs-used
                                     :open-questions :elapsed-ms]
                         :note "Ephemeral — not persisted; no user data stored"}}

  :relationships [
    {:from :symbol  :to :grimoire :type :belongs-to
     :cardinality :many-to-one :cascade :preserve}
    {:from :example :to :grimoire :type :illustrates
     :cardinality :many-to-one :cascade :preserve}]

  :operations {
    :browse-grimoires {
      :actors  [:visitor]
      :outputs [:grimoire-list]
      :note    "All grimoires; loaded from index.edn"}
    :search-symbols {
      :actors  [:visitor]
      :inputs  [:query-string]
      :outputs [:symbol-list]
      :note    "Full-text search across name + synopsis"}
    :interpret-invocation {
      :actors        [:visitor]
      :inputs        [:playground-request]
      :outputs       [:playground-response]
      :preconditions ["input contains valid Conjurer syntax"]
      :postconditions ["response.constructs-used is non-empty"]}}

  :invariants [
    "Every symbol belongs to exactly one grimoire"
    "index.edn is the single source of truth for symbols — never hardcoded in app"])

;; — Taxonomy: grimoire classification for UI filtering

(t/define grimoire-capability-taxonomy
  :purpose "Classify grimoires by primary capability for UI filtering and routing"
  :root    :conjurer-capability

  :criteria {
    :level-1 "What is the grimoire's primary concern?"
    :level-2 "What kind of artefact does it primarily produce?"}

  :membership :monothetic
  :exhaustive true
  :exclusive  true

  :categories [
    {:name    :knowledge-work
     :parent  :conjurer-capability
     :defines "Grimoires that extract, model, or reason about domain knowledge"
     :members [:domain :semantics :reasoning :taxonomy]}
    {:name    :construction
     :parent  :conjurer-capability
     :defines "Grimoires that generate working artefacts: code, data, interfaces"
     :members [:core :data :web]}
    {:name    :coordination
     :parent  :conjurer-capability
     :defines "Grimoires that orchestrate processes, agents, or communication"
     :members [:orchestrate :agent :eloquence]}]

  :manifest grimoire-taxonomy)

;; — Business rules for the playground

(r/rules playground-rules
  :rules [
    {:name     :rate-limit-by-ip
     :if       "more than 20 playground requests from the same IP in 10 minutes"
     :then     "return 429 with retry-after header"
     :strength :definitive
     :source   "security decision 2025-11-05"}
    {:name     :max-input-length
     :if       "playground input exceeds 4000 characters"
     :then     "return 400 — input too long"
     :strength :definitive}
    {:name     :no-persistence
     :if       "playground session completes"
     :then     "discard session data — do not store user input or output"
     :strength :definitive
     :source   "privacy non-negotiable in assume block"}]
  :active-in :session)

;; — Lore: patterns for this specific project

(lore conjurer-site-patterns
  :patterns [
    {:name      :domain-package-is-the-core
     :when      "implementing any business logic or data transformation"
     :apply     "Put it in packages/domain as a pure function.
                 Import it from the shell (React component or Hono handler).
                 Never put logic in components or handlers directly."
     :rationale "TSF++ imperative shell / pure functional core.
                 Domain functions are trivially testable in isolation."}

    {:name      :boundary-at-every-edge
     :when      "receiving data from outside the process — HTTP request, index.edn, .md file"
     :apply     "Parse with a Zod schema from @tsfpp/boundary before using.
                 Return Result<T, ParseError> from the parser.
                 Never trust the shape of external data."
     :rationale "Type safety only holds if we validate at the boundary.
                 TypeScript types are a lie beyond process boundaries."}

    {:name      :index-edn-is-the-source
     :when      "displaying or processing grimoire/symbol data in the app"
     :apply     "Load from index.edn at build time via a Vite plugin.
                 Parse into typed domain objects once at startup.
                 Never duplicate symbol metadata in the app codebase."
     :rationale "Single source of truth. index.edn is maintained by the
                 Conjurer spec; the app consumes it."}

    {:name      :playground-is-thin-proxy
     :when      "implementing the playground API endpoint"
     :apply     "The handler validates input (boundary), calls MCP client
                 (@tsfpp/agents), formats response. No interpretation logic
                 in the handler itself — that belongs to the MCP server."
     :rationale "Separation of concerns. The handler coordinates; the
                 MCP server interprets. Swapping the LLM backend requires
                 changing one config value, not the handler."}]

  :anti-patterns [
    {:name    :logic-in-component
     :avoid   "Writing transformation or business logic inside a React component"
     :because "Untestable without a DOM; couples UI to domain; violates TSF++ core/shell split"}
    {:name    :schema-in-handler
     :avoid   "Defining Zod schemas inline in a Hono handler"
     :because "Schemas are reusable domain contracts — they belong in packages/domain/src/boundary/"}
    {:name    :hardcoded-symbol-data
     :avoid   "Copying grimoire or symbol data directly into the app source"
     :because "index.edn is the source of truth; duplication diverges instantly"}]

  :active-in :session)

;; ─────────────────────────────────────────────────────────────────────────
;; SECTION 6 — TARGETS  [split by concern in multi-file layout]
;; ─────────────────────────────────────────────────────────────────────────

;; ── Monorepo workspace structure ─────────────────────────────────────────

(target :monorepo-scaffold
  :language  :typescript
  :standard  :tsfpp
  :produces  [:project-scaffold]
  :style     {:package-manager   :pnpm
              :workspace-root    "conjurer-site/"
              :node-version      "22"
              :package-structure
                "conjurer-site/
                 ├── pnpm-workspace.yaml
                 ├── package.json           (root — scripts only, no deps)
                 ├── eslint.config.ts       (extends @tsfpp/eslint-config)
                 ├── .github/
                 │   └── workflows/
                 │       ├── ci.yml         (typecheck, lint, test on every PR)
                 │       └── deploy.yml     (deploy to CF Pages on main merge)
                 ├── apps/
                 │   ├── web/               (React SPA)
                 │   │   ├── package.json
                 │   │   ├── tsconfig.json  (extends @tsfpp/tsconfig/app)
                 │   │   ├── vite.config.ts
                 │   │   └── src/
                 │   │       ├── main.tsx
                 │   │       ├── App.tsx
                 │   │       ├── flags.ts            (feature flags)
                 │   │       ├── routes/
                 │   │       │   ├── home/
                 │   │       │   │   ├── HomePage.tsx
                 │   │       │   │   └── HomePage.test.tsx
                 │   │       │   ├── grimoires/
                 │   │       │   │   ├── GrimoiresPage.tsx
                 │   │       │   │   └── GrimoirePage.tsx
                 │   │       │   └── playground/
                 │   │       │       └── PlaygroundPage.tsx
                 │   │       ├── components/          (route-local, not shared)
                 │   │       └── hooks/
                 │   └── api/               (Hono on CF Workers)
                 │       ├── package.json
                 │       ├── tsconfig.json  (extends @tsfpp/tsconfig/worker)
                 │       └── src/
                 │           ├── index.ts            (Hono app entrypoint)
                 │           ├── routes/
                 │           │   ├── grimoires.ts
                 │           │   ├── symbols.ts
                 │           │   └── playground.ts
                 │           └── adapters/
                 │               └── mcp-client.ts   (wraps @tsfpp/agents)
                 └── packages/
                     ├── domain/            (pure functional core — zero framework deps)
                     │   ├── package.json
                     │   ├── tsconfig.json  (extends @tsfpp/tsconfig/library)
                     │   └── src/
                     │       ├── grimoire/
                     │       │   ├── index.ts        (public API — named exports)
                     │       │   ├── grimoire.ts     (pure fns: filter, search, sort)
                     │       │   ├── grimoire.test.ts
                     │       │   └── boundary/
                     │       │       └── grimoire-schema.ts  (Zod schemas)
                     │       ├── symbol/
                     │       │   ├── index.ts
                     │       │   ├── symbol.ts
                     │       │   ├── symbol.test.ts
                     │       │   └── boundary/
                     │       │       └── symbol-schema.ts
                     │       └── playground/
                     │           ├── index.ts
                     │           ├── playground.ts
                     │           └── boundary/
                     │               └── playground-schema.ts
                     └── ui/                (shared React components)
                         ├── package.json
                         ├── tsconfig.json
                         └── src/
                             ├── ConjurerCode/      (syntax-highlighted code block)
                             ├── GrimoireCard/      (grimoire summary card)
                             ├── SymbolCard/        (symbol detail card)
                             ├── SearchBar/
                             └── InvocationExample/"})

;; ── Domain package (packages/domain) ─────────────────────────────────────

(target :domain-pkg
  :language  :typescript
  :standard  :tsfpp
  :produces  [:library]
  :scope     [:grimoire :symbol :playground-request :playground-response]
  :from      conjurer-site-domain
  :style     {
    :dependencies       "@tsfpp/prelude @tsfpp/boundary"
    :no-runtime-deps    [:react :hono :fetch]
    :exports-from       "src/grimoire/index.ts src/symbol/index.ts src/playground/index.ts"
    :test-coverage      :all-pure-functions}
  :notes "
    Each subdomain (grimoire/, symbol/, playground/) follows the same shape:
    - index.ts:          public named exports — types + functions
    - {domain}.ts:       pure transformation functions using pipe() and Result<T,E>
    - {domain}.test.ts:  vitest tests, no mocking needed (pure functions)
    - boundary/{}.ts:    Zod schemas; parse() returns Result<T, ParseError>

    Example from packages/domain/src/grimoire/grimoire.ts:
    ─────────────────────────────────────────────────────
    import { pipe, Result, Option } from '@tsfpp/prelude'
    import type { Grimoire, Symbol } from './index'

    export const filterByCapability = (
      grimoires: ReadonlyArray<Grimoire>,
      capability: string
    ): ReadonlyArray<Grimoire> =>
      grimoires.filter(g =>
        g.constructs.some(group =>
          group.symbols.some(s => s.synopsis.toLowerCase().includes(capability))
        )
      )

    export const findByNamespace = (
      grimoires: ReadonlyArray<Grimoire>,
      namespace: string
    ): Option<Grimoire> =>
      Option.fromNullable(grimoires.find(g => g.namespace === namespace))

    export const searchSymbols = (
      query: string,
      symbols: ReadonlyArray<Symbol>
    ): ReadonlyArray<Symbol> => {
      const q = query.toLowerCase()
      return symbols.filter(s =>
        s.name.toLowerCase().includes(q) ||
        s.synopsis.toLowerCase().includes(q) ||
        s.keyParams.some(p => p.toLowerCase().includes(q))
      )
    }
    ─────────────────────────────────────────────────────
    No try/catch. No mutation. No side effects. Trivially testable.")

;; ── API (apps/api) ────────────────────────────────────────────────────────

(target :api
  :language  :typescript
  :framework :hono
  :standard  :tsfpp
  :produces  [:rest-api :openapi]
  :scope     [:grimoire :symbol :playground-request :playground-response]
  :from      conjurer-site-domain
  :style     {
    :runtime       :cloudflare-workers
    :cors-origins  ["https://conjurer.dev" "http://localhost:5173"]
    :error-format  :rfc-7807}
  :notes "
    Route structure — thin handlers only. All logic in packages/domain.

    GET  /api/grimoires          → list all grimoires from index.edn
    GET  /api/grimoires/:name    → single grimoire with all symbols
    GET  /api/symbols            → all symbols; ?q= for search
    POST /api/playground         → interpret Conjurer input via MCP

    Handler pattern (imperative shell):
    ────────────────────────────────────────────────
    import { Hono } from 'hono'
    import { zValidator } from '@hono/zod-validator'
    import { playgroundRequestSchema } from '@conjurer-site/domain'
    import { callMcp } from '../adapters/mcp-client'

    const playground = new Hono()

    playground.post(
      '/',
      zValidator('json', playgroundRequestSchema),  // boundary
      async (c) => {
        const body = c.req.valid('json')            // typed, validated

        const result = await callMcp({              // imperative I/O
          tool: 'interpret',
          input: body.input,
          context: body.context ?? {}
        })

        if (result.isErr()) {
          return c.json(
            { type: 'https://conjurer.dev/errors/mcp-failure',
              title: 'Interpretation failed',
              status: 502,
              detail: result.error.message },
            502
          )
        }

        return c.json(result.value)                  // happy path
      }
    )
    ────────────────────────────────────────────────
    No logic in handlers. The handler coordinates; domain fns transform.
    RFC 7807 error format throughout.")

;; ── Web app (apps/web) ────────────────────────────────────────────────────

(target :web-app
  :language  :typescript
  :framework :react
  :standard  :tsfpp
  :produces  [:spa]
  :scope     [:grimoire :symbol :playground-session]
  :from      conjurer-site-domain
  :style     {
    :routing         :react-router-v7
    :styling         :tailwind-v4
    :code-highlight  :shiki
    :state           :react-query-for-server-state
    :animations      :framer-motion
    :accessibility   :wcag-aa}
  :notes "
    Page routes — one component per route, co-located with its own tests:
    /                  → routes/home/HomePage.tsx
    /grimoires         → routes/grimoires/GrimoiresPage.tsx
    /grimoires/:name   → routes/grimoires/GrimoirePage.tsx
    /playground        → routes/playground/PlaygroundPage.tsx
    /getting-started   → routes/getting-started/GettingStartedPage.tsx

    Shared UI components from packages/ui — imported, not reimplemented:
    <ConjurerCode>     Shiki-highlighted .cnj code block
    <GrimoireCard>     Summary card for browse grid
    <SymbolCard>       Symbol detail with params and synopsis
    <SearchBar>        Controlled search with debounce

    Feature flags (src/flags.ts):
    PLAYGROUND_ENABLED   default: true in prod / true in dev
    ANALYTICS_ENABLED    default: false until analytics decision is made

    HomePage layout (not a single giant App.tsx):
    ────────────────────────────────────────────────────────────
    <Header />                   ← navigation, dark mode toggle
    <HeroSection />              ← Bosch image, tagline, CTA
    <WhatIsConjurerSection />    ← the 296-char description + Marlowe quote
    <GrimoireHighlights />       ← cards for 3 featured grimoires
    <InteractiveTeaserSection /> ← one live example, link to playground
    <GetStartedSection />        ← SKILL install steps, IDE links
    <Footer />
    ────────────────────────────────────────────────────────────
    Each section is its own component in routes/home/sections/.
    No section component exceeds 80 lines. Logic lives in domain.")

;; ── Infrastructure ────────────────────────────────────────────────────────

(target :infra
  :language  :yaml
  :produces  [:github-actions :dockerfile]
  :style     {
    :deploy-target      :cloudflare-pages
    :api-deploy-target  :cloudflare-workers
    :ci-runner          :ubuntu-latest
    :node-version       "22"
    :pnpm-version       "9"}
  :notes "
    CI (ci.yml) — runs on every push and PR:
    1. pnpm install --frozen-lockfile
    2. pnpm run typecheck          (tsc --noEmit across all packages)
    3. pnpm run lint               (eslint with @tsfpp/eslint-config)
    4. pnpm run test               (vitest run — unit tests for domain package)
    5. pnpm run build              (vite build apps/web)
    All steps must pass. No merge to main without green CI.

    Deploy (deploy.yml) — runs on push to main only:
    1. Run CI steps
    2. Deploy apps/web to Cloudflare Pages
    3. Deploy apps/api to Cloudflare Workers
    Blue/green via CF's built-in preview deployments on PRs.

    Environment variables (set in CF dashboard, not in repo):
    CONJURER_MCP_URL         hosted MCP server endpoint
    CONJURER_MCP_API_KEY     server-side only — never in browser bundle
    RATE_LIMIT_WINDOW_MS     default 600000 (10 min)
    RATE_LIMIT_MAX_REQUESTS  default 20")

;; ─────────────────────────────────────────────────────────────────────────
;; SECTION 7 — HANDOVERS
;; ─────────────────────────────────────────────────────────────────────────

(handover :to :typescript-agent
  :from    conjurer-site-charter
  :scope   [:monorepo-scaffold :domain-pkg]
  :include [:charter :domain-model :target-specs :assets :decisions]
  :briefing
    "Set up the pnpm monorepo and implement the domain package first.
     The domain package must have zero framework dependencies — only
     @tsfpp/prelude and @tsfpp/boundary. Start with the grimoire subdomain:
     load index.edn, parse it through boundary schemas, expose typed
     filterByCapability / findByNamespace / searchSymbols functions.
     All pure — no side effects, no I/O. Full vitest coverage.
     TSF++ standard throughout — see the registered asset. The constraint
     'no barrel files' means each subdomain exposes its public API through
     its own index.ts, not through a root index.ts that re-exports everything."
  :produces     [:monorepo-scaffold :domain-package-source :domain-package-tests]
  :return-to    :current-session
  :on-completion :merge-results)

(handover :to :typescript-agent
  :from    conjurer-site-charter
  :scope   [:api]
  :include [:charter :domain-model :target-specs :assets :decisions]
  :briefing
    "Implement the Hono API once the domain package is complete and its
     types are exported. Four routes: grimoires list, grimoire detail,
     symbol search, playground proxy. Handlers are thin — validate at
     boundary using domain Zod schemas, call domain functions or the
     MCP adapter, return typed responses. RFC 7807 error format.
     Rate limiting for the playground route per playground-rules.
     Cloudflare Workers runtime — no Node.js APIs."
  :produces     [:api-source :openapi-spec]
  :return-to    :current-session
  :on-completion :merge-results)

(handover :to :typescript-agent
  :from    conjurer-site-charter
  :scope   [:web-app :ui-package]
  :include [:charter :domain-model :target-specs :assets :decisions]
  :briefing
    "Implement the React SPA. Build the shared UI package first (ConjurerCode,
     GrimoireCard, SymbolCard, SearchBar). Then the app routes. HomePage is the
     priority: Hero with Bosch image and Marlowe epigraph, grimoire highlights,
     interactive teaser, get-started section. No section component over 80 lines.
     Logic that is not directly rendering belongs in packages/domain or a hook.
     Shiki for code highlighting in ConjurerCode — it must handle Clojure syntax
     for .cnj files. React Query for all API calls. WCAG AA minimum."
  :produces     [:ui-package-source :web-app-source]
  :return-to    :current-session
  :on-completion :merge-results)

(handover :to :typescript-agent
  :from    conjurer-site-charter
  :scope   [:infra]
  :include [:charter :target-specs :assets]
  :briefing
    "Write the GitHub Actions workflows (ci.yml and deploy.yml) and
     the pnpm-workspace.yaml. CI runs typecheck, lint, test, build in sequence.
     Deploy runs only on main and only after CI passes. Cloudflare Pages for
     the web app; Cloudflare Workers for the API. Environment variables are
     injected from CF dashboard secrets — document which variables are required
     in a .env.example at the repo root."
  :produces     [:github-actions :pnpm-workspace-config :env-example]
  :return-to    :current-session
  :on-completion :merge-results)
